# Enter your code here. Read input from STDIN. Print output to STDOUT
# Reading input
n, m = map(int, input().split())
storage = list(map(int, input().split()))
set_a = set(map(int, input().split()))
set_b = set(map(int, input().split()))

# Calculating happiness
happiness = 0
for i in storage:
    if i in set_a:
        happiness += 1
    elif i in set_b:
        happiness -= 1

print(happiness)
