# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

def validate_mobile_number(number_string):
    """
    Checks if a string is a valid 10-digit mobile number starting with 7, 8, or 9.
    """
    pattern = r"^[789]\d{9}$"
    if re.match(pattern, number_string):
        return "YES"
    else:
        return "NO"

# Read the number of inputs
try:
    N = int(input())
    for _ in range(N):
        number_string = input()
        print(validate_mobile_number(number_string))
except EOFError:
    pass
except ValueError:
    pass
