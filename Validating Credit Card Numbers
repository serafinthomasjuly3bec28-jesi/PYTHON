import re

def validate_credit_card(card):
    # 1. Check the basic structure:
    # ^[456]           : Starts with 4, 5, or 6
    # (                : Start of group
    #  \d{15}          : Either 15 more digits (total 16)
    #  |               : OR
    #  \d{3}(-\d{4}){3}: 3 digits, then 3 groups of (hyphen + 4 digits)
    # )                : End of group
    # $                : End of string
    structure_pattern = r"^[456](\d{15}|\d{3}(-\d{4}){3})$"
    
    if not re.match(structure_pattern, card):
        return "Invalid"
    
    # 2. Check for 4 or more consecutive repeated digits:
    # We remove hyphens first to check the sequence of digits
    card_digits = card.replace("-", "")
    # (\d)\1{3,} matches any digit followed by the same digit 3+ more times
    if re.search(r"(\d)\1{3,}", card_digits):
        return "Invalid"
    
    return "Valid"

# Read number of inputs
try:
    n = int(input().strip())
    for _ in range(n):
        card_string = input().strip()
        print(validate_credit_card(card_string))
except EOFError:
    pass
